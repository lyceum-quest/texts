# sentence_id = 88
# translation_lang = en
# prose_translation = Since it is an imitation of an action and is performed by certain actors, who must be people of a certain character and thought (for it is through these that we say that actions themselves are of a certain character...), it naturally follows that there are two causes of actions—thought and character—and it is according to these that everyone succeeds or fails.
