# sentence_id = 444
# document_id = 0086-034
# subdoc = 22.13
# translation_lang = en
# prose_translation = For Aeschylus in his Philoctetes wrote "a cancer that eats the flesh of my foot," but Euripides substituted "feasts upon" for "eats."
