# sentence_id = 364
# document_id = 0086-034
# subdoc = 19.8
# translation_lang = en
# prose_translation = For why should anyone suppose that there is an error in what Protagoras criticizes—that Homer, thinking he is praying, actually commands when he says "Sing, Goddess, the wrath"—for to bid someone to do or not to do something is, he says, a command.
