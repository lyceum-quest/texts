# sentence_id = 155
# Ref = 1.3.5
# translation_lang = en
# prose_translation = And no one shall ever say that I, after leading Greeks into the land of the barbarians, betrayed the Greeks and chose the friendship of the barbarians; but since you do not wish to obey me, I shall follow with you and endure whatever may be necessary.
# literal_translation = And never shall-say no-one that I Greeks having-led into the barbarians, having-betrayed the Greeks the of-the barbarians friendship I-chose, but since you to-me not wish to-obey, I with you shall-follow and what-ever would it-may-be-necessary I-shall-endure.
