# translation_lang = en
# prose_translation = Xenias, then, arrived at Sardis with the troops from the cities, about four thousand hoplites; Proxenus was also there with about fifteen hundred hoplites and five hundred light-armed troops; Sophaenetus the Stymphalian with a thousand hoplites; Socrates the Achaean with about five hundred hoplites; and Pasion the Megarian arrived with three hundred hoplites and three hundred peltasts.
